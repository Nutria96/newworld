{
  "name": "chongseb-publisher",
  "version": "1.0.0",
  "private": true,
  "description": "Publicador oficial y auditable de CHONGSEB",
  "main": "publisher.js",
  "scripts": {
    "start": "node setup-chongseb.js",
    "publish:list": "node publisher.js --list",
    "publish:schedule": "node publisher.js --schedule",
    "publish:dry": "node publisher.js --run-due --dry-run",
    "discord:setup": "node setup-discord.js --rebuild",
    "discord:exclusive": "node setup-exclusive.js",
    "discord:multiverso": "node setup-multiverso.js",
    "discord:chongseb": "node setup-chongseb.js",
    "discord:rebuild": "node setup-chongseb.js --rebuild"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.16.0",
    "@simplewebauthn/server": "^13.2.2",
    "@supabase/supabase-js": "^2.110.8",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.1",
    "node-cron": "^4.2.1",
    "stripe": "^22.3.2"
  },
  "engines": {
    "node": ">=20"
  }
}
