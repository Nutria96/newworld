# LinkedIn Posts API
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:organization:
LINKEDIN_VERSION=202606

# Facebook Page Graph API
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
META_GRAPH_VERSION=v23.0

# X API v2: token OAuth de usuario con permiso tweet.write
TWITTER_ACCESS_TOKEN=

# Instagram Graph API: cuenta profesional enlazada a una página
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# Webhook propio/autorizado. WhatsApp Cloud API no publica en grupos.
WHATSAPP_WEBHOOK_URL=

# Controles
PUBLISHER_MIN_INTERVAL_MINUTES=60
PUBLISHER_DRY_RUN=true

# Backend de IA y memoria
DEEPSEEK_API_KEY=
AI_MODEL=deepseek-v4-flash
# Búsqueda web real para solicitudes de enlaces, fuentes o información actual.
SERPAPI_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
# Subidas privadas directas al bucket (50 MiB por archivo, 5 por mensaje).
MEDIA_UPLOADS_ENABLED=false
MEDIA_MAX_FILE_BYTES=52428800
MEDIA_MAX_FILES_PER_MESSAGE=5
MEDIA_SIGNED_URL_TTL_SECONDS=900
# Genera 32 bytes aleatorios en Base64. Firma la sesión multimedia pública.
MEDIA_SESSION_SECRET=

# Acceso restringido. Genera ambas con 32 bytes aleatorios en Base64.
IDENTITY_ENCRYPTION_KEY=
ADULT_SESSION_SECRET=
JWT_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Dominio sin protocolo y origen HTTPS exacto.
WEBAUTHN_RP_ID=chongseb.netlify.app
WEBAUTHN_ORIGIN=https://chongseb.netlify.app

# Mercado Pago, PayPal y catálogo. Los importes son centavos MXN.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=sandbox
MERCADOPAGO_PREMIUM_PLAN_ID=
MERCADOPAGO_VIP_PLAN_ID=
PAYPAL_PREMIUM_PLAN_ID=
PAYPAL_VIP_PLAN_ID=
PAYPAL_WEBHOOK_ID=
MERCADOPAGO_STORE_PLAN_ID=
PAYPAL_STORE_PLAN_ID=
STORES_API_URL=
STORES_API_KEY=
# Metadatos públicos de contenido VIP. Los archivos reales permanecen privados.
VIP_CONTENT_JSON=[]
SITE_URL=https://chongseb.netlify.app
DONATION_AMOUNT_CENTS=5000
# Ejemplo de formato: {"flyer":{"name":"Flyer","amount":30000}}
SERVICE_CATALOG_JSON=

# SHA-256 de la contraseña elegida; nunca guardes la contraseña directa.
ADMIN_PASSWORD_HASH=
# Firma los Pases Hogar. Genera al menos 32 bytes aleatorios.
HOUSEHOLD_ACCESS_SECRET=

# Proveedor visual OpenAI-compatible opcional
VISION_API_URL=
VISION_API_KEY=
VISION_MODEL=

# Bot de Discord. DISCORD_TOKEN es secreto y nunca debe subirse a Git.
DISCORD_TOKEN=
# Opcional si el bot pertenece exactamente a un servidor; obligatorio si pertenece a varios.
GUILD_ID=
# Prefijo de los comandos del bot exclusivo.
DISCORD_COMMAND_PREFIX=!
# Recursos visuales opcionales. Usa rutas absolutas a archivos propios o con licencia.
DISCORD_ICON_PATH=
DISCORD_BANNER_PATH=
# Carpeta opcional con taco_chill.png, canal_amsterdam.png,
# mexico_flag.png y netherlands_flag.png.
DISCORD_EMOJI_DIR=
# URL HTTPS opcional para la miniatura del embed de bienvenida.
DISCORD_WELCOME_IMAGE_URL=
